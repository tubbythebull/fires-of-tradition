---
import Layout from "$layouts/Layout.astro";

const categories = await getCategories()
async function getCategories() {
	let cats = await Astro.glob('$data/categories/*.md')
	return cats?.map((c) => c.frontmatter)?.sort((a, b) => a.position - b.position)
}
---

<Layout title="Home" description="Welcome to the homepage">

	<section class="VideoHero">
		<video id="hero-video" src="/homepage.mp4" autoplay

  muted

  loop

  playsinline

  webkit-playsinline

  preload="auto"></video>
	</section>

	<script>
		const video = document.getElementById('hero-video');
		async function forcePlay() {

  try {

    await video.play();

    // success: stop listening

    removeListeners();

  } catch (e) {

    // still blocked

  }

}

function removeListeners() {

  events.forEach(event =>

    document.removeEventListener(event, forcePlay)

  );

}

const events = [
'load',
  'touchstart',

  'touchend',

  'mousedown',

  'mouseup',

  'click',

  'scroll',

  'keydown',

  'visibilitychange'

];

// initial attempt

forcePlay();

// retry after ANY interaction

events.forEach(event =>

  document.addEventListener(event, forcePlay, { passive: true })

);

	</script>

	<style>
		.VideoHero {
			position: relative;
			width: 100%;
			aspect-ratio: 21/9;
			overflow: hidden;
			margin: 0;
			padding: 0;
			border: 0;
			& video {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}
	</style>


	<section class="MaxWidthLarge Hero">
		<img src="/test.jpeg" alt="A traditional cast iron fireplace with an electric fire unit, showcasing the perfect blend of classic design and modern technology." class="HeroImage" />
		<header>
			<h1>Timeless Elegance Meets Modern Convenience</h1>
			<p>Discover the perfect marriage of heritage craftsmanship and cutting-edge technology with our collection of traditional cast iron fireplaces featuring state-of-the-art electric fire units.</p>
		</header>
	</section>
	<style>
		.Center {
			text-align: center;
		}
		.Hero {
			max-width: 100%;
			& img.HeroImage {
				width: 100%;
				aspect-ratio: 1.5/1;
				object-fit: cover;
				border-radius: 8px;
				background-color: orange;
			}
			& header {
				padding: 0;
				margin: 0;
				max-width: 60ch;
				& h1 {
					margin: 0;
					padding-block: .25em .05em;
