				}
				& p {
					font-size: 1.25rem;
					margin: 0;
					padding-block: .5em 1.5em;
					text-wrap: balance;
				}
			}
			@media (min-width: 800px) {
				display: grid;
				grid-template-columns: 1fr;
				grid-template-rows: 1fr;
				overflow: hidden;
				& img.HeroImage {
					grid-area: 1 / 1;
					width: 100%;
					aspect-ratio: 1.75/1;
					border-radius: 8px;
					background-color: orange;
				}
				& header {
					grid-area: 1 / 1;
					align-self: end;
					/* display: flex;
					flex-direction: column;
					justify-content: center;
					align-items: center;
					text-align: center; */
					/* padding: 2em; */
					/* backdrop-filter: blur(4px); */
					padding: 0 2rem;
			}
		}



		
	</style>
	

	<section class="MaxWidthLarge" style="background-color: #ccc7bc; padding-block: min(2rem, 5vh); margin-block: 1rem;">

		<!-- <h1>Timeless Elegance Meets Modern Convenience</h1>
		<p>Discover the perfect marriage of heritage craftsmanship and cutting-edge technology with our collection of traditional cast iron fireplaces featuring state-of-the-art electric fire units.</p> -->

		<!-- <p>Explore our collection and discover how tradition and innovation create spaces that feel both authentic and effortlessly comfortable.</p> -->

		<h2 class="Center">Explore our collection</h2>
		<ul class="GridList">
			{categories.map((category:any) => (
				<li>
					<a href={`/${category.slug}`}>
