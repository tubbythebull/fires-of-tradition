export async function getStaticPaths() {
	const Posts = await Astro.glob('$data/products/*.md')

	// const Posts = (await import.meta.glob('$data/products/*.md'))
	return Posts?.map((post) => ({
		// params: { slug: post.file.pathname.split('/').pop().split('.').shift() },
		// params: { product: post.file.split('/').pop().split('.').shift() },
		params: { product: post.frontmatter.slug },
		props: { post },
	}))
}

const { Content, frontmatter, title, description, publishDate, tags} = Astro.props.post;


---

<Layout>
	<Content />
	<pre>{JSON.stringify(frontmatter, null, 2)}</pre>
</Layout>