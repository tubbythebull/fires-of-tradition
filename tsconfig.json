{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "$root/*": ["*"],
      "$src/*": ["src/*"],
      "$components/*": ["src/components/*"],
      "$islands/*": ["src/islands/*"],
      "$config/*": ["src/config/*"],
      "$layouts/*": ["src/layouts/*"],
      "$utils/*": ["src/utils/*"],
      "$stores/*": ["src/stores/*"]
    }
  }
}